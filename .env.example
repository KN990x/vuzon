# vuzon — self-hosted panel for Cloudflare Email Routing
#
# Fill in these two values and start the panel. The first time you open it in a browser
# it asks you to choose your username and password — there is nothing else to configure.
#
# The server refuses to start while one of them is empty or still holds an example value.

# The email domain you manage in Cloudflare, e.g. mydomain.dev
DOMAIN=

# Cloudflare API token. It needs exactly three scopes (see the README):
#   Zone → Email Routing Rules: Edit
#   Account → Email Routing Addresses: Edit
#   Zone → Zone: Read
CF_API_TOKEN=


# --------------------------------------------------------------------------------------
# Everything below is optional. The defaults are meant for a homelab on plain HTTP.
# --------------------------------------------------------------------------------------

# Host port the panel is published on (default 8001).
# VUZON_PORT=8001

# Set to 1 behind HTTPS or a TLS-terminating proxy, so the session cookie is marked
# Secure. Leave it off for plain HTTP on a LAN.
# COOKIE_SECURE=1

# Set behind a reverse proxy (nginx, Traefik…) so the real client IP reaches the login
# rate limit. Accepts a hop count (1, 2, …), loopback / linklocal / uniquelocal, or an
# IP/CIDR list like 10.0.0.0/8.
# TRUST_PROXY=1
