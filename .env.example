# 1) Required. The server refuses to start while any of these is empty, or still holds
#    the example value from this template. AUTH_USER is prefilled; change it if you like.
DOMAIN=
AUTH_USER=admin
AUTH_PASS=
CF_API_TOKEN=

# 2) Required in production / Docker image (NODE_ENV=production): stable session signing key.
#    Must be at least 32 characters. Generate one with:
#        openssl rand -hex 32
#    Never reuse a value published anywhere: the session cookie is signed with it, so a
#    known key lets anyone forge a logged-in session.
SESSION_SECRET=

# 3) Optional: set both CF_ZONE_ID and CF_ACCOUNT_ID if you want to avoid autodetection from DOMAIN.
# CF_ZONE_ID=
# CF_ACCOUNT_ID=

# 4) Optional: set VUZON_PORT to change the host port mapped to the app (Compose).
# VUZON_PORT=8001

# 5) Optional: set TRUST_PROXY behind a reverse proxy so Express and rate limiting see
#    the real client IP (X-Forwarded-*). Off by default. Accepts a hop count (1, 2, …),
#    loopback / linklocal / uniquelocal, or an IP/CIDR list like 10.0.0.0/8.
# TRUST_PROXY=1

# 6) Optional: set COOKIE_SECURE=1 behind HTTPS / a TLS-terminating proxy so the
#    session cookie is marked Secure. Leave unset for homelab HTTP (default).
# COOKIE_SECURE=1
